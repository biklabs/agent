{
  "name": "@biklabs/agent-runner",
  "version": "0.1.0",
  "private": false,
  "description": "BIKLabs terminal-first multi-runtime agent orchestrator (Claude Code, Codex, Cursor, OpenCode, Kiro, OpenClaw)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/biklabs/agent-runner.git"
  },
  "homepage": "https://github.com/biklabs/agent-runner",
  "bugs": {
    "url": "https://github.com/biklabs/agent-runner/issues"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "bin": {
    "bik-agent": "./bik-agent.ts",
    "biklabs-agent-runner": "./runner.ts",
    "biklabs-agent-dispatch": "./dispatch.ts",
    "biklabs-agent-jobs": "./jobs.ts",
    "biklabs-agent-session": "./session-client.ts",
    "biklabs-agent-listen": "./listen.ts",
    "biklabs-agent-status": "./status.ts",
    "biklabs-agent-doctor": "./doctor.ts",
    "biklabs-agent-init": "./init.ts"
  },
  "files": [
    "bik-agent.ts",
    "runner.ts",
    "dispatch.ts",
    "jobs.ts",
    "session-client.ts",
    "listen.ts",
    "status.ts",
    "doctor.ts",
    "init.ts",
    "mcp-runtime.ts",
    "runtime-presets.ts",
    "smoke-matrix.ts",
    "validate.ts",
    "agents.json",
    "README.md",
    "COMPATIBILITY_MATRIX.md",
    "QUALITY_GATES.md",
    "RUNTIME_PROFILES.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "agent": "bun run ./bik-agent.ts",
    "runner": "bun run ./runner.ts",
    "dispatch": "bun run ./dispatch.ts",
    "jobs": "bun run ./jobs.ts",
    "session": "bun run ./session-client.ts",
    "listen": "bun run ./listen.ts",
    "status": "bun run ./status.ts",
    "doctor": "bun run ./doctor.ts",
    "init": "bun run ./init.ts",
    "check": "bun run ./validate.ts",
    "presets": "bun run ./runtime-presets.ts",
    "smoke:matrix": "bun run ./smoke-matrix.ts"
  },
  "keywords": [
    "biklabs",
    "agent",
    "orchestrator",
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "opencode",
    "kiro",
    "openclaw",
    "terminal-first"
  ]
}
